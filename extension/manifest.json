{
  "manifest_version": 3,
  "name": "Skookoo Highlighter",
  "version": "1.0",
  "description": "Highlight text and react with Skookoo.",
  "permissions": ["activeTab", "scripting", "storage", "contextMenus", "tabs"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start", 
    "all_frames": true 
    }
  ],
  "icons": {
    "72": "icon72.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Skookoo",
    "default_icon": {
      "72": "icon72.png"
    }
  }
}