<div style="min-height:100vh; background:linear-gradient(135deg,#f8f9fa,#e9ecef);">

  <section class="hero-section" >
    <div class="mb-3">
      <%= image_tag("shield_key.png", style: "width: 150px;") %>
    </div>
    <h1> Choose Your Plan </h1>
    <p> Unlock premium features and enjoy the full experience. </p>
  </section>

  <section style="margin-top:-40px; padding:40px 20px;">
    <div style="
        max-width:1100px;
        margin:0 auto;
        background:white;
        border-radius:20px;
        padding:35px;
        box-shadow:0 15px 40px rgba(0,0,0,0.06);
    ">
      <%= render 'shared/plans' %>
    </div>
  </section>

</div>
