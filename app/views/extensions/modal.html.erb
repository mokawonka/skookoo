<!DOCTYPE html>
<html lang="en">
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Skookoo — React</title>
  <%= stylesheet_link_tag asset_path('bootstrap.min.css') %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "actiontext" %>
  <%= stylesheet_link_tag asset_path('font-awesome.min.css') %>
  
<style>
  body { 
    padding: 1rem; 
    max-width: 500px; 
    margin: 0 auto; 
    background: transparent;
    font-family: 'League Spartan Bold', sans-serif;
  }

  #highlight {
    position: relative;
    margin: 1.5rem 0;
  }

  #highlight blockquote {
    position: relative;
    border-left: 4px solid #0951a9;
    padding: 0.75rem 1.5rem 0.75rem 2.5rem; 
    margin: 0;
    color: #0951a9;
    background: rgba(9, 81, 169, 0.03);      
    border-radius: 0 8px 8px 0;
    quotes: "“" "”" "‘" "’";                
  }

  #highlight blockquote::before,
  #highlight blockquote::after {
    position: absolute;
    font-size: 3.5rem;
    font-weight: bold;
    color: #0951a9;
    opacity: 0.25;
    line-height: 1;
  }

  #highlight blockquote::before {
    content: open-quote;
    left: 0.6rem;
    top: -0.6rem;
  }

  #highlight blockquote::after {
    content: close-quote;
    right: 0.6rem;
    bottom: -1.2rem;
  }

  #highlight blockquote p,
  #highlight blockquote div {
    margin: 0;
    padding: 0;
  }

  .iframe-icon {
    vertical-align: middle;
  }

  #close-modal-btn{
    position: absolute; top: 16px; right: 16px; z-index: 1000;
    width: 48px; height: 48px; 
    background: rgba(9, 81, 169, 0.08);
    border: none; border-radius: 50%; 
    font-size: 32px; font-weight: 600; 
    color: #0951a9; 
    cursor: pointer; line-height: 1; 
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    transition: all 0.25s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
</style>
</head>

<%= javascript_include_tag asset_path('jquery-3.6.0.min.js') %>
<%= javascript_include_tag asset_path('bootstrap.bundle.min.js') %>
<%= javascript_importmap_tags %>



<body>
    <input type="hidden" id="auth-token" value="<%= params[:token] %>">


  <% if @expired %>
    <!-- ==================== EXPIRED UI ==================== -->
    <div class="text-center p-5 bg-light rounded shadow position-fixed top-50 start-50 translate-middle" 
         style="max-width: 90%; width: 420px;">
      <h5 class="text-danger mb-3">Session expired</h5>
      <p class="text-muted mb-4">Your session has expired.<br>Please reconnect to continue.</p>
      <button class="btn btn-primary px-4" onclick="window.parent.postMessage({ action: 'skookooReconnect' }, '*')">
        Reconnect to Skookoo
      </button>
    </div>

  <% else %>
    <!-- ==================== NORMAL MODAL ==================== -->
    <div id="highlightmodal">

      <button id="close-modal-btn"> × </button>
      <div class="text-center mb-5">
        <h3 class="text-muted">
          <%= image_tag('berry_icon.png', size: "32x32", class: "iframe-icon") %> React with
        </h3>
      </div>

      <%= render "shared/createhighlight" %>

    </div>

    <%= render "shared/premiumteaser" %>
  <% end %>

  <!-- Scripts only for normal modal -->
  <% unless @expired %>

    <script>

    $('#emojiresults').empty().hide();
    $('#gifresults').empty().hide();
    $('#gifsearch').val('');
    $('#cfi').html("<%= j @cfi %>");
    $('#highlight').find('blockquote').html("<%= j @quote %>");
    $('#authors').html('<%= j @fromauthors %>');
    $('#title').html('<%= j @fromtitle %>');

    $('#gifform').hide();
    $('#commentform').hide();

    document.getElementById('close-modal-btn').addEventListener('click', function() {
         window.parent.postMessage({ action: 'closeSkookooModal' }, '*');
    });
    
    </script>
  <% end %>

</body>
</html>