<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Skookoo — Log in</title>

  <!-- Google Fonts: League Spartan -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@700&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag asset_path('bootstrap.min.css') %>

  <style>
    :root {
      --primary: #0951a9;
      --primary-dark: #073e84;
      --light-bg: #f8f9fa;
    }

    body {
      font-family: 'League Spartan', sans-serif;
      background: linear-gradient(135deg, var(--light-bg) 0%, #e9ecef 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
      padding: 1rem;
    }

    .auth-card {
      background: white;
      border-radius: 1rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
      overflow: hidden;
      max-width: 420px;
      width: 100%;
      transition: transform 0.2s ease;
    }

    .auth-card:hover {
      transform: translateY(-5px);
    }

    .auth-header {
      background: var(--primary);
      color: white;
      padding: 2rem 1.5rem;
      text-align: center;
    }

    .auth-header h1 {
      margin: 0;
      font-weight: 700;
      font-size: 1.8rem;
    }

    .auth-body {
      padding: 2rem 1.5rem;
      text-align: center;
    }

    .btn-primary {
      background: var(--primary);
      border: none;
      font-weight: 700;
      padding: 0.75rem 2rem;
      border-radius: 0.5rem;
      transition: all 0.2s ease;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }

    .text-muted {
      font-size: 0.95rem;
      color: #6c757d;
    }

    .logo {
      max-width: 140px;
      margin-bottom: 1rem;
    }
  </style>
</head>
<body>
  <div class="auth-card">
    <div class="auth-header">
      <%= image_tag("skookoo_logo_100.png", class: "logo", alt: "Skookoo") %>
    </div>

    <div class="auth-body">
      <h5 class="mb-4 fw-bold">Please log in to continue</h5>

      <p class="text-muted mb-4">
        Your session has expired or you are not logged in.<br>
        Sign in to access your documents, vocabulary, and highlights.
      </p>

      <a href="<%= login_path %>" class="btn btn-primary btn-lg w-100" target="_blank">
        Log in to Skookoo
      </a>

      <p class="mt-4 text-muted small">
        After logging in, close this tab and refresh the previous page.<br>
        Or <a href="<%= root_path %>" class="text-primary">return to home</a>.
      </p>
    </div>
  </div>
</body>
</html>