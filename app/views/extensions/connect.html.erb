
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Connecting Extension</title>
    <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      text-align: center;
      padding: 60px 20px;
      background: #f5f5f5;
    }

    .card {
      background: white;
      max-width: 420px;
      margin: auto;
      padding: 40px;
      border-radius: 14px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }

    h3 { margin-bottom: 10px; }
    p { font-size: 14px; color: #666; }

    .success { color: #1e8e3e; font-weight: 600; }
    .error { color: #d93025; font-weight: 600; }
  </style>
</head>
<body>

  <div class="card">
    <h3>Connecting Skookoo…</h3>
    <p id="status">Securing connection…</p>
  </div>

  <script>
    (function() {
      const statusEl = document.getElementById("status");
      console.log("[CONNECT] Page loaded. Opener exists?", !!window.opener);

      if (!window.opener) {
        statusEl.textContent = "No opener window found.";
        statusEl.className = "error";
        console.error("[CONNECT] No window.opener – cannot send token");
        return;
      }

      const extensionOrigin = "<%= @extension_origin %>";
      console.log("[CONNECT] Extension origin passed:", extensionOrigin);

      const token = "<%= @token %>";
      console.log("[CONNECT] Token to send (length):", token.length);

      // Try multiple origins in dev to cover localhost/127.0.0.1 variations
      const possibleOrigins = [
        extensionOrigin,
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "*"
      ];

      const sendToken = () => {
        possibleOrigins.forEach(origin => {
          console.log("[CONNECT] Attempting postMessage to:", origin);
          try {
            window.opener.postMessage(
              {
                type: "SKOOKOO_TOKEN",
                token: token
              },
              origin
            );
            console.log("[CONNECT] postMessage sent to", origin);
          } catch (e) {
            console.error("[CONNECT] postMessage failed for", origin, e);
          }
        });

        statusEl.textContent = "Extension connected successfully.";
        statusEl.className = "success";

        setTimeout(() => {
          window.close();
        }, 1500);
      };

      // Slight delay to ensure listener is ready
      setTimeout(sendToken, 300);

    })();
  </script>

</body>
</html>