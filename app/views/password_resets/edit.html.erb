<div class="auth-card-wrap">
  <div class="auth-card">
    <div class="auth-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#0951a9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>

    <h4 class="auth-title">Choose a new password</h4>
    <p class="auth-sub">Make it strong and memorable.</p>

    <%= form_with url: password_reset_path(params[:id]), scope: :user, method: :patch, data: { turbo: false } do |f| %>
      <div class="auth-field">
        <label class="auth-label">New password</label>
        <%= f.password_field :password, placeholder: "••••••••", required: true, class: "auth-input" %>
      </div>
      <div class="auth-field">
        <label class="auth-label">Confirm password</label>
        <%= f.password_field :password_confirmation, placeholder: "••••••••", required: true, class: "auth-input" %>
      </div>
      <%= f.submit "Update password", class: "auth-btn" %>
    <% end %>
  </div>
</div>