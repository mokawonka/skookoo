<%
    avatarclass = type == "parent" ? "parent-reply-avatar" : "child-reply-avatar"
    toggleclass = type == "parent" ? "parent-reply-toggle" : "child-reply-toggle"
    onereplyclass = type == "parent" ? "parent-onereply" : "child-onereply"

    poster = User.find_by_id(reply.userid)

    subreplies = reply.getsubreplies

    owner_id = Highlight.find(reply.highlightid).userid 
    highlightowner = User.find(owner_id).username

    iffromposter = reply.userid == owner_id ? "fromposter-onereply" : ""

%>


<div id="<%=reply.id%>">

    <!-- displaying reply -->
    <% if !reply.deleted %>

        <!-- Avatar -->
        <% if poster.avatar.attached? %>
            <%= link_to image_tag(poster.avatar.variant(resize_to_limit:[64, 64]), class: avatarclass), user_path(poster.username), class: "user-hover-trigger", data: { user_id: poster.id }, style:'height:fit-content' %>
        <% else %>
            <%= link_to image_tag("default-avatar.svg", class: avatarclass),  user_path(poster.username), class: "user-hover-trigger", data: { user_id: poster.id }, style:'height:fit-content' %>
        <% end %>

        <!-- collapser / expander if children present -->
        <% if subreplies.count > 0 %>
            <%= image_tag "replies-collapse.png",
                    size: "17x17",
                    id: "toggle-#{reply.id}",
                    class: toggleclass,
                    style: "cursor: pointer;",
                    data: {
                    collapse: asset_path("replies-collapse.png"),
                    expand:   asset_path("replies-expand.png"),
                    state: "collapse"
                    } %>

            <script>
            $('#toggle-<%= reply.id %>').on('click', function(e) {
                e.preventDefault();
            
                const $img = $(this);
                const $children = $('#children-<%= reply.id %>');
                const duration = 350;   // ← change this to make it faster/slower (in ms)
            
                if ($img.data('state') === 'collapse') {
                  // Collapse: change icon first, then slide up
                  $img.attr('src', $img.data('expand'));
                  
                  $children.slideUp(duration, function() {
                    $img.data('state', 'expand');
                  });
                  
                } else {
                  // Expand: slide down first, then change icon
                  $children.slideDown(duration, function() {
                    $img.attr('src', $img.data('collapse'));
                    $img.data('state', 'collapse');
                  });
                }
              });
            </script>
        <% end %>


        <div class="onereply <%=onereplyclass%> <%=iffromposter%>">
            <div class="replyheader">
                By <%= link_to poster.username, user_path(poster.username), class: "user-hover-trigger", data: { user_id: poster.id } %> <%=time_ago_in_words(reply.created_at)%> ago
                <% if reply.edited %>(edited)<% end %>
            </div>
            <div class=replybody>
                <%= linkify_mentions(reply.content) %>
            </div>
            <div class=replyactions>

                <span><%= render 'shared/voting_system', entity: reply, fromuser: current_user,
                                                                        touser: User.find(reply.userid),
                                                                        type: "minor" %></span>

                <span><%= link_to 'reply', logged_in? ? reply_path(reply) : login_path(return_to: request.fullpath), remote: logged_in? ? "true" : false %></span>

                <% if current_user != nil %>

                    <% if current_user.username == poster.username %>
                        <span><%= link_to 'edit', edit_reply_path(reply), remote: "true" , class: "editcomment" %></span>
                        <span><%= link_to 'delete', reply, method: :delete, remote:"true", data: { confirm: "Delete, Are you sure?"} %></span>
                    <% elsif current_user.username == highlightowner %>
                        <span><%= link_to 'delete', reply, method: :delete, remote:"true", data: { confirm: "Delete, Are you sure?"} %></span>
                    <% end %>

                <% end %>
            </div>
            <div class="d-none pt-3 replytobox"></div>
        </div>
        
    <% else %>
    
        <% if subreplies.count > 0 %>
            <div class="onereply text-center gray">[deleted]</div>
        <% end %>

    <% end %>


</div>
