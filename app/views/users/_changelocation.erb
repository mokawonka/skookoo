
<%= form_with model: user, url: user_path(user), method: :patch, local: true, data: { turbo: false }  do |form| %>
    <div class="field">
        <%= form.text_field :location, placeholder: "Hometown", spellcheck: false, id: 'locationinput' %>
    </div>
    <div class="actions">
        <%= form.submit "save", class: 'd-none', id: 'changelocation' %>
    </div>
<% end %>