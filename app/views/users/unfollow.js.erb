var isFollowing =
  $('#hover-followbutton').text().trim() === 'Following' ||
  $('#followbutton').text().trim() === 'Following';

$('#followbutton')
  .text('Follow')
  .attr('href', '<%= user_follow_path(@user) %>');

$('#hover-followbutton')
  .text('Follow')
  .attr('href', '<%= user_follow_path(@user) %>');

if (isFollowing) {

  var followers = parseInt($('#hover-followers-count').text());
  if (!isNaN(followers)) {
    $('#hover-followers-count').text(followers - 1);
  }

  var following = parseInt($('#profile-following-count').text());
  if (!isNaN(following)) {
    $('#profile-following-count').text((following - 1) + ' Following');
  }

}