// Update the button in the followitem list
$('#followbutton-<%= @user.id %>')
  .text('Follow')
  .attr('href', '<%= user_follow_path(@user) %>');

// Update profile page buttons (keep your existing logic)
$('#followbutton')
  .text('Follow')
  .attr('href', '<%= user_follow_path(@user) %>');

$('#hover-followbutton')
  .text('Follow')
  .attr('href', '<%= user_follow_path(@user) %>');

// Update follower count
var followers = parseInt($('#hover-followers-count').text());
if (!isNaN(followers)) {
  $('#hover-followers-count').text(followers - 1);
}