
<%= form_with model: user, url: user_path(user), method: :patch, local: true, data: { turbo: false } do |form| %>
    <div class="field">
        <%= form.text_area :bio, placeholder: "Add your bio ...", spellcheck: false, id: 'bioinput' %>
    </div>
    <div class="actions">
        <%= form.submit "save", class: 'd-none', id: 'changebio' %>
    </div>
<% end %>