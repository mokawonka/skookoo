<%= form_with model: user, url: user_path(user), method: :patch, local: true, data: { turbo: false } , html: { multipart: true } do |f| %>
  <%= f.file_field :background, id: 'user_background', style: 'display: none;' %>
  <%= f.submit 'Update Background', id: 'changebackground', style: 'display: none;' %>
<% end %>