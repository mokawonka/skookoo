<div class="page-container">

  <section class="hero-section text-center py-5">
    <div class="mb-3">
      <%= image_tag("store.png", style: "width: 150px;") %>
    </div>
    <h1 class="fw-bold mb-3">Store</h1>
    <p class="lead mb-4">&ldquo;<%= @highlight.quote.truncate(100) %>&rdquo;</p>
  </section>

  <section class="merch-section">
    <div class="merch-container">
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">

        <% products = [
          {name: "Candies", image: "merch/candies.png", description: "Your quote, wrapping candies.", price: 19.99},
          {name: "Chocolate tablet", image: "merch/chocolate.png", description: "Your quote, crafted in chocolate", price: 19.99},
          {name: "Shirt", image: "merch/shirt.png", description: "Premium cotton shirt with custom print", price: 24.99},
          {name: "Mug", image: "merch/mug.png", description: "Ceramic mug with durable quote engraving", price: 24.99},
          {name: "Hat", image: "merch/hat.png", description: "Adjustable cap with printed highlight", price: 24.99},
          {name: "Poster", image: "merch/poster.png", description: "High-quality matte poster print", price: 19.99}
        ] %>

        <% colors = [
          {name: "Orange", value: "#ff7a00"},
          {name: "Blue", value: "#0951a9"},
          {name: "Red", value: "#d90429"},
          {name: "Green", value: "#00a711"}
        ] %>

        <% products.each do |product| %>
          <div class="col">
            <div class="card">
              <div class="card-img-top  zoom-trigger" data-img="<%= image_path(product[:image]) %>">
                <%= image_tag product[:image], alt: product[:name], class: "img-fluid" %>
              </div>

              <div class="card-body text-center">
                <h5 class="card-title"><%= product[:name] %></h5>
                <p class="product-price fw-bold">$<%= product[:price] %></p>
                <p class="card-text"><%= product[:description] %></p>
                <p class="highlight-quote">"<%= @highlight.quote.truncate(60) %>"</p>

                <%= form_with model: @merch_order, url: merch_orders_path, local: true, class: "order-form" do |f| %>
                <%= f.hidden_field :highlight_id, value: @highlight.id %>
                <%= f.hidden_field :design_text, value: @highlight.quote %>
                <%= f.hidden_field :product_type, value: product[:name] %>

                <% if ["Candies", "Chocolate tablet"].include?(product[:name]) %>
                  <%= f.hidden_field :color, value: "N/A" %> 
                <% else %>
                <div class="color-picker">
                  <% colors.each_with_index do |color, index| %>
                    <label class="color-option">
                      <%= f.radio_button :color, color[:name], checked: index == 0 %>
                      <span class="color-circle" style="background-color:<%= color[:value] %>;"></span>
                    </label>
                  <% end %>
                </div>
                <% end %>

                <div class="quantity-wrapper">
                  <label class="quantity-label">Quantity</label>
                  <%= f.number_field :quantity,
                        value: 1,
                        min: 1,
                        class: "form-control quantity-input" %>
                </div>

                <% if @existing_orders[product[:name]] %>
                  <button class="btn btn-placed mt-3" disabled>
                    ✓ Pre-order placed
                  </button>
                <% else %>
                  <%= f.submit "Pre-order Now", class: "btn btn-order mt-3" %>
                <% end %>

              <% end %>

              </div>
            </div>
          </div>
        <% end %>

      </div>
    </div>
  </section>
</div>

<div class="zoom-overlay" id="zoomOverlay">
  <span class="zoom-close" id="zoomClose">&times;</span>
  <img src="" id="zoomImg" alt="Zoomed product">
</div>

<script>
  const overlay = document.getElementById('zoomOverlay');
  const zoomImg = document.getElementById('zoomImg');

  document.querySelectorAll('.zoom-trigger').forEach(el => {
    el.addEventListener('click', () => {
      zoomImg.src = el.dataset.img;
      overlay.classList.add('active');
    });
  });

  overlay.addEventListener('click', () => {
    overlay.classList.remove('active');
  });

  // Close on Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') overlay.classList.remove('active');
  });
</script>