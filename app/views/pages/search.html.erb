<div class="sr-page-header">
  <h3 class="sr-page-title">
    <%= image_tag('ladder.png', size: "33x33") %>
    Search
    <span class="sr-page-meta">
      <span class="sr-page-count"><%= @users.count + @highlights.count %> results</span>
      for <span class="sr-page-query">"<%= @query %>"</span>
    </span>
  </h3>
</div>

<div class="sr-page">

  <% if @users.empty? && @highlights.empty? %>
    <div class="sr-empty">
      <%= image_tag 'empty_basket.png', size: '80x80' %>
      <p>No results found for "<%= @query %>"</p>
    </div>

  <% else %>

    <% if @users.any? %>
      <div class="sr-section">
        <div class="sr-section-label">
          People
          <span class="sr-count"><%= @users.count %></span>
        </div>
        <div class="sr-people-grid">
          <% @users.each do |user| %>
            <a href="<%= user_path(user.username) %>" class="sr-person-card">
              <div class="sr-avatar">
                <% if user.avatar.attached? %>
                  <%= image_tag user.avatar.variant(resize_to_limit: [40, 40]) %>
                <% else %>
                  <%= image_tag "default-avatar.svg" %>
                <% end %>
              </div>
              <div class="sr-person-meta">
                <div class="sr-person-name">
                  <%= user.name %>
                  <% if user.pomologist? %>
                      <%= render 'shared/premiumbadge' %>
                  <% end %>
                </div>
                <div class="sr-person-handle">@<%= user.username %></div>
              </div>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @highlights.any? %>
      <div class="sr-section">
        <div class="sr-section-label">
          Highlights
          <span class="sr-count"><%= @highlights.count %></span>
        </div>
        <div class="sr-quotes-list">
          <% @highlights.each do |h| %>
            <a href="<%= highlight_path(h) %>" class="sr-quote-card">
              <div class="sr-quote-mark">"</div>
              <div class="sr-quote-text"><%= truncate(h.quote, length: 220) %></div>
              <div class="sr-quote-meta">
                <% if h.fromauthors.present? %>
                  <span class="sr-quote-author"><%= h.fromauthors %></span>
                <% end %>
                <% if h.fromtitle.present? %>
                  <span class="sr-quote-dot">·</span>
                  <span class="sr-quote-title"><%= h.fromtitle %></span>
                <% end %>
              </div>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

    <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>

  <% end %>

</div>