<div id="documents">
  <div class="documents-container">
    <div class="documents-add-row">
      <%= link_to '+ Add Documents', new_epub_path, class: "btn btn-warning border-3 border-dark" %>
    </div>

    <% if @records.count > 0 %>
      <div class="documents-grid">
        <% @records.order('updated_at DESC').each do |document| %>
          <% affiliated_epub = document.epub %>
          <div class="document-card">

            <div class="document-cover">
              <%= link_to document do %>
                <% if affiliated_epub&.cover_pic.attached? && affiliated_epub.cover_pic.variable? %>
                  <%= image_tag affiliated_epub.cover_pic.variant(resize_to_limit: [300, 300]) %>
                <% else %>
                  <%= image_tag 'default_epub_cover.png' %>
                <% end %>
              <% end %>

              <div class="document-overlay">
                <span class="document-type">EPUB</span>
              </div>

              <div class="document-actions">
                <%# Share button — wire up to your share logic %>
                <button class="action-btn btn-share" title="Share">↗</button>
                <%= button_to '✕', document, method: :delete,
                      class: "action-btn btn-delete",
                      title: "Delete",
                      data: { confirm: "Are you sure?" } %>
              </div>
            </div>

            <div class="document-progress-track">
              <div class="document-progress-fill"
                   style="width: <%= (document.progress * 100).ceil %>%"></div>
            </div>

            <div class="document-meta">
              <div class="document-date">Added <%= document.created_at.to_date.to_fs(:long_ordinal) %></div>
              <div class="document-title"><%= document.title %></div>
              <div class="document-author"><%= document.authors %></div>
            </div>

            <div class="document-footer">
              <%= link_to 'Open', document, class: "btn-open" %>
              <span class="document-progress-label"><%= (document.progress * 100).ceil %>% read</span>
            </div>

          </div>
        <% end %>
      </div>
    <% else %>
      <div class="documents-empty">
        <%= image_tag 'sad_bee.png', size: '100x100' %>
        <p>You don't have any documents</p>
      </div>
    <% end %>

    <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
  </div>
</div>