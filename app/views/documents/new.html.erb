<div id="write-page" class="container my-5" style="max-width: 960px;">

  <!-- Clean segmented toggle – no circles/dots -->
  <div class="d-flex justify-content-center mb-5">
    <div class="segmented-toggle rounded-pill bg-light p-1">
      <input type="radio" name="write-mode" id="mode-essay" value="essay" checked autocomplete="off">
      <label for="mode-essay" class="segment-label">Essay</label>

      <input type="radio" name="write-mode" id="mode-book" value="book" autocomplete="off">
      <label for="mode-book" class="segment-label">Book</label>

      <span class="segment-slider"></span>
    </div>
  </div>

  <!-- Header – straight blue focus line -->
  <div class="mb-5">
    <input type="text" id="title-input" class="title-input" placeholder="Title" maxlength="200" autocomplete="off">
    <input type="text" id="authors-input" class="authors-input mt-3" placeholder="Your name or pen name" value="<%= current_user&.name || '' %>" autocomplete="off">
  </div>

  <!-- Essay Mode -->
  <div id="essay-mode" class="mode-content">
    <div class="editor-wrapper">
      <%= rich_text_area_tag "content", nil,
                             id: "essay-content",
                             placeholder: "Begin your essay here...",
                             class: "trix-content",
                             data: { "trix-placeholder": "Begin your essay here..." } %>
    </div>
  </div>

  <!-- Book Mode -->
  <div id="book-mode" class="mode-content d-none">
    <div id="chapters-container" class="mb-5"></div>

    <button id="add-chapter-btn" type="button" class="add-chapter-btn w-100 py-4">
      <i class="bi bi-plus-circle-fill me-2 fs-4"></i> Add New Chapter
    </button>
  </div>


  <div class="footer d-flex flex-column flex-md-row justify-content-between align-items-center gap-4 mt-5 pt-4 border-top">
    <label class="toggle-container d-flex align-items-center gap-3 cursor-pointer user-select-none">
      <span class="fw-medium fs-5">Make public</span>
      <div class="modern-toggle">
        <%= check_box_tag :ispublic, "1", true, id: "ispublic" %>
        <span class="toggle-knob"></span>
      </div>
    </label>

    <div class="d-flex gap-3">
      <button id="save-draft-btn" type="button" class="btn btn-outline-secondary px-4">
        Save Draft
      </button>
      <button id="publish-btn" class="publish-btn btn btn-lg px-5 py-3">
        Publish
      </button>
    </div>
  </div>

</div>

</div>

<template id="chapter-template">
  <div class="chapter-block">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h5 class="mb-0 fw-semibold">Chapter [NUM]</h5>
      <div>
        <button type="button" class="btn btn-sm btn-outline-secondary me-2 move-up">↑ Up</button>
        <button type="button" class="btn btn-sm btn-outline-secondary me-2 move-down">↓ Down</button>
        <button type="button" class="btn btn-sm btn-danger remove-chapter">Remove</button>
      </div>
    </div>
    <input type="text" class="chapter-title form-control mb-3 fs-5" placeholder="Chapter Title" required>
    <%= rich_text_area_tag "temp[content]", "", class: "trix-content" %>  <!-- no name/id here -->
  </div>
</template>

<style>
  /* ── Segmented Toggle – no circles/dots ── */
  .segmented-toggle {
    position: relative;
    display: inline-flex;
    background: #f8f9fa;
    border-radius: 999px;
    padding: 4px;
  }

  .segment-label {
    position: relative;
    z-index: 2;
    padding: 12px 48px;
    font-weight: 500;
    color: #495057;
    background: transparent;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.25s;
  }

  input[type="radio"] {
    display: none; /* hide native radio circle */
  }

  input[type="radio"]:checked + .segment-label {
    color: white;
    font-weight: 600;
  }

  .segment-slider {
    position: absolute;
    top: 4px; bottom: 4px; left: 4px;
    width: calc(50% - 8px);
    background: #0951a9;
    border-radius: 999px;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  #mode-book:checked ~ .segment-slider {
    transform: translateX(100%);
  }

  
.title-input,
.authors-input,
.chapter-title {
  width: 100%;
  border: none;
  border-bottom: 1px solid #e0e0e0;     /* thinner line by default */
  outline: none;
  background: transparent;
  padding: 10px 0;
  transition: border-bottom-color 0.3s ease, color 0.2s ease;
  border-radius: 0;
}

/* Title – prominent */
.title-input {
  font-size: 2.4rem;
  font-weight: 700;
  color: #111;
}

/* Author – more discrete */
.authors-input {
  font-size: 1.25rem;                    /* smaller than title */
  font-weight: 400;
  color: #666;                           /* lighter color */
  padding: 8px 0;
  border-bottom: 1px solid #e8e8e8;      /* even lighter line */
  opacity: 0.85;                         /* slightly faded */
  transition: opacity 0.25s ease, border-bottom-color 0.3s ease;
}

/* Chapter titles – medium prominence */
.chapter-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: #222;
}

/* Focus states – straight blue line, sharp ends */
.title-input:focus,
.authors-input:focus,
.chapter-title:focus {
  border-bottom: 3px solid #0951a9;
  border-radius: 0 !important;
  box-shadow: none;
  outline: none;
}

/* Author gets a subtle opacity boost on focus */
.authors-input:focus {
  opacity: 1;
  color: #222;
}

/* Ensure no rounding anywhere */
#write-page input,
#write-page textarea {
  border-radius: 0 !important;
}

/* Optional: remove pseudo-element if it was causing visual artifacts */
.title-input:focus::after,
.authors-input:focus::after,
.chapter-title:focus::after {
  display: none;   /* ← disable if you added it earlier */
}
  .modern-toggle {
    position: relative;
    width: 68px;
    height: 36px;
  }

  .modern-toggle input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-knob {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #d0d5dd;
    border-radius: 36px;
    transition: background-color 0.3s ease;
  }

  .toggle-knob::before {
    position: absolute;
    content: "";
    height: 28px;
    width: 28px;
    left: 4px;
    bottom: 4px;
    background-color: white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    transition: transform 0.3s ease;
  }

  input:checked + .toggle-knob {
    background-color: #0951a9;
  }

  input:checked + .toggle-knob::before {
    transform: translateX(32px);
  }

  .add-chapter-btn {
    background: transparent;
    border: 2px dashed #0951a9;
    color: #0951a9;
    font-weight: 600;
    font-size: 1.2rem;
    border-radius: 12px;
    transition: all 0.3s;
  }

  .add-chapter-btn:hover {
    background: #0951a9;
    color: white;
    border-color: transparent;
  }

  .publish-btn {
    background: #0951a9;
    border: none;
    color: white;
    font-weight: 600;
    font-size: 1.25rem;
    border-radius: 12px;
    transition: all 0.3s;
  }

  .publish-btn:hover {
    background: #07428c;
    transform: translateY(-2px);
  }

  .chapter-block {
    background: white;
    border-radius: 12px;
    padding: 28px;
    margin-bottom: 32px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transition: box-shadow 0.25s;
  }

  .chapter-block:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.09);
  }

  #write-page .trix-content {
    min-height: 520px;
    font-size: 1.2rem;
    line-height: 1.85;
  }

  .editor-wrapper {
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  #write-page .trix-content:focus-within,
  #write-page .trix-content:focus {
    border: 3px solid #0951a9 !important;
    border-radius: 21px !important;
  }


</style>


<script>

const saveDraftBtn = document.getElementById('save-draft-btn');

function updateSaveButtonState(isSaving = false, justSaved = false) {
  if (isSaving) {
    saveDraftBtn.textContent = 'Saving…';
    saveDraftBtn.disabled = true;
  } else if (justSaved) {
    saveDraftBtn.textContent = 'Saved';
    saveDraftBtn.disabled = true;
    setTimeout(() => {
      saveDraftBtn.textContent = 'Save Draft';
      saveDraftBtn.disabled = false;
    }, 2000);
  } else {
    saveDraftBtn.textContent = 'Save Draft';
    saveDraftBtn.disabled = false;
  }
}

saveDraftBtn.onclick = () => {
  updateSaveButtonState(true);
  saveDraft();
  updateSaveButtonState(false, true);
};


function fitTitleText() {
  const input = document.getElementById('title-input');
  const maxSize = 2.4;
  const minSize = 0.9;
  const basePx = parseFloat(getComputedStyle(document.documentElement).fontSize);

  input.style.fontSize = maxSize + 'rem';
  while (input.scrollWidth > input.clientWidth && parseFloat(input.style.fontSize) > minSize) {
    const current = parseFloat(input.style.fontSize);
    input.style.fontSize = (current - 0.05) + 'rem';
  }
}

document.getElementById('title-input').addEventListener('input', fitTitleText);
window.addEventListener('resize', fitTitleText);

// Mode switching
var currentMode = 'essay';

document.querySelectorAll('input[name="write-mode"]').forEach(radio => {
  radio.addEventListener('change', e => {
    currentMode = e.target.value;
    document.getElementById('essay-mode').classList.toggle('d-none', currentMode !== 'essay');
    document.getElementById('book-mode').classList.toggle('d-none', currentMode !== 'book');
    document.getElementById('title-input').focus();
  });
});

// Draft management
var DRAFT_KEY = "write_draft_v1";
var draftSaveTimeout = null;

function scheduleDraftSave() {
  clearTimeout(draftSaveTimeout);
  draftSaveTimeout = setTimeout(saveDraft, 2000); // save every 2s after typing
}

function saveDraft() {
  const draft = {
    mode: currentMode,
    title: document.getElementById('title-input')?.value || "",
    authors: document.getElementById('authors-input')?.value || "",
    isPublic: document.getElementById('ispublic')?.checked || false,
    essayContent: "",
    chapters: []
  };

  // Essay content
  const essayTrix = document.querySelector('#essay-content');
  if (essayTrix) {
    draft.essayContent = essayTrix.innerHTML || '';
  }

  // Chapters content (each independent Trix)
  document.querySelectorAll('.chapter-block').forEach(block => {
    const title = block.querySelector('.chapter-title')?.value || "";
    const trixEditor = block.querySelector('.trix-content');
    const content = trixEditor ? trixEditor.innerHTML : '';

    draft.chapters.push({ title, content });
  });

  localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
}

function loadDraft() {
  const raw = localStorage.getItem(DRAFT_KEY);
  if (!raw) return;

  const draft = JSON.parse(raw);

  // Restore shared fields
  if (draft.title) document.getElementById('title-input').value = draft.title;
  if (draft.authors) document.getElementById('authors-input').value = draft.authors;
  if (document.getElementById('ispublic')) document.getElementById('ispublic').checked = draft.isPublic;

  // Restore mode
  if (draft.mode === 'book') {
    document.getElementById('mode-book').checked = true;
    document.getElementById('book-mode').classList.remove('d-none');
    document.getElementById('essay-mode').classList.add('d-none');
    currentMode = 'book';
  }

  // Restore essay
  if (draft.essayContent) {
    const essayTrix = document.querySelector('#essay-content');
    if (essayTrix && essayTrix.editor) {
      essayTrix.editor.loadHTML(draft.essayContent);
    }
  }

  // Restore chapters (add them and load content)
  if (draft.chapters && draft.chapters.length > 0) {
    draft.chapters.forEach(chap => {
      addChapter(); // add empty chapter

      const block = document.querySelector('#chapters-container').lastElementChild;
      if (block) {
        block.querySelector('.chapter-title').value = chap.title || '';

        const trixEditor = block.querySelector('.trix-content');
        if (trixEditor && trixEditor.editor) {
          trixEditor.editor.loadHTML(chap.content || '');
        }
      }
    });
  }

  // Trigger save after load to keep in sync
  scheduleDraftSave();
}

// Chapter logic
function addChapter() {
  const container = document.getElementById('chapters-container');
  const chapterIndex = container.children.length;

  // Clone template
  const template = document.getElementById('chapter-template').content.cloneNode(true);

  // Set chapter number
  template.querySelector('h5').textContent = `Chapter ${chapterIndex + 1}`;

  // Append to DOM
  container.appendChild(template);

  // Get the new block
  const block = container.lastElementChild;

  // Get .trix-content
  const trixElement = block.querySelector('.trix-content');

  if (trixElement) {
    const uniqueHiddenId = `chapter-hidden-${Date.now()}-${chapterIndex}`;
    trixElement.setAttribute('input', uniqueHiddenId);

    const hiddenInput = document.createElement('input');
    hiddenInput.type = 'hidden';
    hiddenInput.name = `chapters[${chapterIndex}][content]`;
    hiddenInput.id = uniqueHiddenId;
    hiddenInput.value = '';

    trixElement.parentNode.insertBefore(hiddenInput, trixElement.nextSibling);

    new Trix.Editor(trixElement); // Trix will now sync to the hidden input with matching id
  }

  // Add remove/move listeners
  block.querySelector('.remove-chapter').onclick = () => {
    block.remove();
    renumberChapters();
    scheduleDraftSave();
  };

  block.querySelector('.move-up').onclick = () => {
    moveChapter(block, -1);
    scheduleDraftSave(); 
  };

  block.querySelector('.move-down').onclick = () => {
    moveChapter(block, 1);
    scheduleDraftSave();
  };

}


function renumberChapters() {
  document.querySelectorAll('.chapter-block').forEach((block, i) => {
    block.querySelector('h5').textContent = `Chapter ${i + 1}`;
  });
}

function moveChapter(block, dir) {
  const container = document.getElementById('chapters-container');
  const children = Array.from(container.children);
  const idx = children.indexOf(block);
  const newIdx = idx + dir;

  if (newIdx < 0 || newIdx >= children.length) return;

  if (dir < 0) {
    container.insertBefore(block, children[newIdx]);
  } else {
    container.insertBefore(block, children[newIdx + 1] || null);
  }

  renumberChapters();
  scheduleDraftSave();
}

// Init
document.addEventListener('turbo:load', () => {
  fitTitleText();
  loadDraft();

  // Global save triggers
  document.addEventListener('trix-change', scheduleDraftSave);
  document.getElementById('title-input').addEventListener('input', scheduleDraftSave);
  document.getElementById('authors-input').addEventListener('input', scheduleDraftSave);
  document.getElementById('ispublic').addEventListener('change', scheduleDraftSave);

  document.getElementById('add-chapter-btn').onclick = addChapter;

  document.getElementById('mode-book').addEventListener('change', () => {
    if (document.querySelectorAll('.chapter-block').length === 0) {
      addChapter();
    }
  });

  // Publish handler
  document.getElementById('publish-btn').addEventListener('click', async () => {
    const btn = document.getElementById('publish-btn');
    btn.disabled = true;
    btn.textContent = currentMode === 'essay' ? 'Publishing Essay…' : 'Publishing Book…';

    const title = document.getElementById('title-input').value.trim();
    if (!title) {
      alert("Title is required");
      btn.disabled = false;
      btn.textContent = 'Publish';
      return;
    }

    const authors = document.getElementById('authors-input').value.trim();
    const isPublic = document.getElementById('ispublic').checked ? "1" : "0";

    const formData = new FormData();
    formData.append('document[title]', title);
    formData.append('document[authors]', authors);
    formData.append('document[ispublic]', isPublic);
    formData.append('authenticity_token', '<%= form_authenticity_token %>');

    if (currentMode === 'essay') {
      // Essay mode: get hidden input next to trix-editor
      const trixEditor = document.getElementById('essay-content');
      const hiddenInput = document.getElementById(trixEditor.getAttribute('input'));
      const content = hiddenInput?.value?.trim() || '';

      if (!content || content === '<div><br></div>' || content.trim() === '') {
        alert("Please write some content for your essay");
        btn.disabled = false;
        btn.textContent = 'Publish';
        return;
      }

      formData.append('document[content]', content);
      formData.append('document[mode]', 'essay');
    } else {
      // Book mode - collect all chapters correctly
      const chapters = document.querySelectorAll('.chapter-block');
      let hasValidChapter = false;

      chapters.forEach((block, index) => {
        const chapTitle = block.querySelector('.chapter-title').value.trim();

        const hiddenInput = block.querySelector('input[type="hidden"][name^="chapters"]');
        const content = hiddenInput?.value?.trim() || '';

        // Better check: is there meaningful content?
        const hasMeaningfulContent = content && 
                                    content.length > 10 && 
                                    content !== '<div><br></div>' && 
                                    content !== '<div></div>' && 
                                    !/^\s*<br\s*\/?>\s*$/.test(content) &&  // just <br>
                                    content.trim() !== '';

        if (chapTitle || hasMeaningfulContent) {
          formData.append(`document[chapters][${index}][title]`, chapTitle);
          formData.append(`document[chapters][${index}][content]`, content);
          if (hasMeaningfulContent) {
            hasValidChapter = true;
          }
        }
      });

      if (!hasValidChapter) {
        alert("Add at least one chapter with content");
        btn.disabled = false;
        btn.textContent = 'Publish';
        return;
      }

      formData.append('document[mode]', 'book');
    }

    try {
      const response = await fetch('<%= documents_path %>', {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (response.redirected) {
        window.location.href = response.url;
        localStorage.removeItem(DRAFT_KEY);
        return;
      }

      if (!response.ok) {
        let errorMsg = 'Publishing failed.';
        try {
          const data = await response.json();
          errorMsg = data.error || errorMsg;
        } catch {
          // fallback if not JSON
        }
        console.error('Server error:', response.status, errorMsg);
        alert(errorMsg);
        return;
      }

    } catch (error) {
      console.error('Fetch error:', error);
      alert('Network error while publishing. Please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Publish';
    }

  });
});
</script>